# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VAPI_API_KEY: Authorization token for Vapi telephony services.
VAPI_API_KEY="your_vapi_api_key_here"

# VAPI_PHONE_NUMBER_ID: Outbound phone number ID in Vapi.
VAPI_PHONE_NUMBER_ID="your_vapi_phone_number_id_here"

# VAPI_ASSISTANT_ID: The assistant ID for Sarah (optional, defaults to preset fallback).
VAPI_ASSISTANT_ID="your_vapi_assistant_id_here"

# NEXT_PUBLIC_SUPABASE_URL: The URL of your Supabase project.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"

# NEXT_PUBLIC_SUPABASE_ANON_KEY: The public anonymous key for Supabase client connection.
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# RESEND_API_KEY: Authentication token for Resend transactional email service.
RESEND_API_KEY="your_resend_api_key_here"

# RESEND_FROM_EMAIL: The sender email address verified in your Resend account.
# If you are using the sandbox/free tier without a custom domain, you MUST use "onboarding@resend.dev".
# If you have linked your verified domain (e.g., tekguyz.com), you can use "Real Stone & Granite <info@tekguyz.com>".
RESEND_FROM_EMAIL="onboarding@resend.dev"

